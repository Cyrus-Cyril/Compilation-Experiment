// PERF-003 测试：常量折叠 + 死代码消除 + 拷贝传播 + 代数化简
int main() {
    int a = 42;
    int b = 20 + 30;       // 应折叠为 50
    int c = a * 2 + 100;   // a=42, 42*2=84, 84+100=184
    int c2 = c / 2;        // 184/2=92
    int d = b - c2;        // 50-92=-42
    int e = d + 0;         // 代数化简：d + 0 = d
    int f = e * 1;         // 代数化简：e * 1 = e
    int g = f - f;         // 代数化简：f - f = 0
    int h = g * 42;        // 0 * 42 = 0
    return h;              // 应返回 0
}